# ==========================================
# @sindicatosdpMAD - Bot de X autónomo
# Configuración de credenciales
# Copia este fichero a .env y rellena los valores
# ==========================================

# GetXAPI (docs.getxapi.com) - API key para búsquedas
# Obtén tu key en: https://docs.getxapi.com/
GETXAPI_KEY=tu-api-key-aqui

# URL base de la API
GETXAPI_BASE_URL=https://api.getxapi.com

# Auth token de X (necesario para responder tweets)
# Se obtiene de las cookies de x.com (F12 -> Application -> Cookies -> x.com -> auth_token)
X_AUTH_TOKEN=tu-auth-token-aqui

# Usuario de la cuenta
X_USERNAME=sindicatosdpMAD

# ==========================================
# Panel web detrás de Caddy Auth
# ==========================================

# Puerto local que expondrá Caddy en el host: http://IP:PUERTO
PANEL_PORT=8080

# Usuario de Basic Auth para el panel
CADDY_AUTH_USER=admin

# Hash bcrypt de la contraseña. Genera uno con:
# docker run --rm -it caddy:2 caddy hash-password
# IMPORTANTE: si el hash contiene $, ponlo entre comillas simples para Docker Compose.
CADDY_AUTH_HASH='pega-aqui-el-hash-generado'

# Protección defensiva dentro de la app: exige cabecera inyectada por Caddy.
# Actívalo cuando uses Docker+Caddy.
REQUIRE_PROXY_AUTH_HEADER=true
REMOTE_USER_HEADER=Remote-User
